{
  "name": "bowlingroom-professional",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "cms:dev": "npm run dev --prefix apps/cms",
    "cms:build": "npm run build --prefix apps/cms",
    "cms:start": "npm run start --prefix apps/cms",
    "cms:import:legacy-pages": "npm run import:legacy-pages --prefix apps/cms",
    "cms:import": "tsx scripts/import-to-payload.ts",
    "lint": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "format": "prettier --write .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx scripts/seed.ts",
    "db:import:legacy": "tsx scripts/import-legacy-content.ts",
    "test:smoke": "tsx scripts/smoke.ts",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@astrojs/node": "^9.1.0",
    "@astrojs/sitemap": "^3.6.0",
    "@prisma/client": "^6.4.1",
    "astro": "^5.3.0",
    "cookie": "^1.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/vercel": "^9.0.4",
    "@eslint/js": "^9.39.3",
    "@types/cookie": "^0.6.0",
    "@types/node": "^22.13.9",
    "eslint": "^9.21.0",
    "eslint-plugin-astro": "^0.34.0",
    "prettier": "^3.5.2",
    "prettier-plugin-astro": "^0.14.1",
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "prisma": {
    "seed": "tsx scripts/seed.ts"
  }
}
