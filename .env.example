# Core
NODE_ENV=development
PUBLIC_SITE_URL=http://localhost:4321
DEPLOY_TARGET=node
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bowlingroom?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/bowlingroom?schema=public
CMS_STORAGE_MODE=hybrid
CMS_PLATFORM=custom
CMS_PAYLOAD_READ_MODE=preview-only
ADMIN_LOCAL_BYPASS=true
PAYLOAD_CMS_URL=http://127.0.0.1:4000
PAYLOAD_API_TOKEN=
PAYLOAD_PREVIEW_SECRET=replace-with-preview-secret
PAYLOAD_ALLOW_UNSIGNED_LOCAL_PREVIEW=true

# Auth
ADMIN_SESSION_COOKIE=br_admin_session
ADMIN_CSRF_COOKIE=br_admin_csrf
ADMIN_SESSION_TTL_HOURS=24
ADMIN_DEFAULT_EMAIL=admin@bowlingroom.local
ADMIN_DEFAULT_PASSWORD=ChangeMe123!

# Integrations
ZENDESK_INBOUND_EMAIL=
ZENDESK_WEBHOOK_URL=
PREVO_API_URL=
PREVO_API_KEY=

# Tracking
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
META_PIXEL_ID=

# Security
CSRF_SECRET=replace-with-random-secret
FORM_RATE_LIMIT_WINDOW_MS=60000
FORM_RATE_LIMIT_MAX=20
LOGIN_RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX=10
